@article{zhang_hydrogen_2016,
	title = {Hydrogen separation by porous phosphorene: {A} periodical {DFT} study},
	volume = {41},
	issn = {0360-3199},
	shorttitle = {Hydrogen separation by porous phosphorene},
	url = {http://www.sciencedirect.com/science/article/pii/S0360319916331809},
	doi = {10.1016/j.ijhydene.2016.10.108},
	abstract = {We have examined theoretically the stability of porous phosphorene and its application in hydrogen separation from gas mixture by employing first-principles calculations. The self-passivated pore of phosphorene was designed by removing six phosphorous atoms, reaching to the formation of covalent bonds among marginal atoms spontaneously. The gas permeability and selectivity were obtained for the porous phosphorene membrane. The results indicated that the self-passivated defect in phosphorene is inert to the gas mixture containing N2, CO, CO2, H2O, and CH4 molecules, and the porous phosphorene performed high selectivity for hydrogen over other gas molecules compared with previous graphene and silicene-based membranes. Our results unveiled the great potential of porous phosphorene as a promising membrane in hydrogen purification.},
	number = {48},
	urldate = {2017-03-13},
	journal = {International Journal of Hydrogen Energy},
	author = {Zhang, Yayun and Hao, Feng and Xiao, Hang and Liu, Chao and Shi, Xiaoyang and Chen, Xi},
	month = dec,
	year = {2016},
	keywords = {Hydrogen separation, Porous phosphorene, Gas mixture, First-principles calculation},
	pages = {23067--23074},
