	author = {Fang, Zhongqi and Chen, Bin and Lin, Shiyun and Ye, Wei and Xiao, Hang and Chen, Xi},
	month = dec,
	year = {2018},
	keywords = {Anisotropic mechanical property, Antler bone, Crack-extending routes, Fractal model, Test and observation},
	pages = {1--10},
