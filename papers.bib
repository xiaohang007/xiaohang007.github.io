	journal = {Journal of Environmental Chemical Engineering},
	author = {Li, Chong and Wang, Yan and Hou, Jinqiao and Wang, Huanming and Luo, Jingting and Fu, Chen and Ren, Fujian and Zhang, Jikai and Ong, Huiling and Lu, Chenze and Xiao, Hang and Chen, Xi and Tao, Ran and Chen, Yuzhi and Fu, Yongqing and Wu, Qiang and Li, Xuejin},
	month = dec,
