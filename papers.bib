	month = aug,
	year = {2020},
	note = {00010},
	keywords = {capture CO from ambient air, climate change, CO sorbent, DAC technology, direct air capture CO, global warming, ion hydration, negative carbon emission, negative emission technology, surface and interface science},
	pages = {1823--1837},
	file = {Shi 等。 - 2020 - Moisture-Driven CO2 Sorbents.pdf:C\:\\Users\\XXX007\\OneDrive - Lingnan University\\Documents\\Zotero\\storage\\QXUITGTC\\Shi 等。 - 2020 - Moisture-Driven CO2 Sorbents.pdf:application/pdf},
